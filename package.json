{
  "name": "agrogest-vsm",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @agrogest/mobile --filter @agrogest/api --filter @agrogest/admin-web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:api": "vitest run apps/api/src/integration",
    "test:watch": "vitest",
    "docs:check": "node tools/quality/validate-docs.mjs",
    "quality:branch-protection": "node tools/quality/check-branch-protection.mjs",
    "quality:ci": "pnpm check && pnpm test:coverage && pnpm build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm docs:check",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/database/backup-postgres.ps1",
    "db:restore": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/database/restore-postgres.ps1",
    "db:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/database/test-bootstrap-restore.ps1",
    "ai:agents": "opencode.cmd agent list",
    "ai:models": "opencode.cmd models deepseek",
    "ai:skills": "opencode.cmd debug skill",
    "ai:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ai/doctor.ps1",
    "ai:review": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ai/review-diff.ps1",
    "docs:graph": "opengem graph ."
  },
  "devDependencies": {
    "@cubocompany/opengem": "0.7.5",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.4"
  }
}
