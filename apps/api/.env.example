NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Agrogest_VSM
DB_USER=postgres
DB_PASSWORD=replace-with-your-postgres-password
DB_SCHEMA=public
DB_SSL=false
JWT_ACCESS_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace-with-another-random-secret-of-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=VSM
SEED_ADMIN_EMAIL=admin@agrogestvsm.local
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
