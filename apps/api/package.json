{
  "name": "@agrogest/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm build && node scripts/dev-runner.cjs",
    "build": "tsc -p tsconfig.build.json",
    "seed:auth": "pnpm build && node dist/scripts/seed-auth.js",
    "migrate": "pnpm build && node dist/scripts/migrate-database.js",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.12",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^10.4.12",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "pdfmake": "^0.3.7",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/pdfmake": "^0.3.2"
  }
}
