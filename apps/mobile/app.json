{
  "expo": {
    "name": "AgroGest VSM",
    "slug": "agrogest-vsm-mobile",
    "scheme": "agrogest-vsm",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite usar la ubicacion del dispositivo para registrar la ubicacion de la visita de campo."
        }
      ]
    ]
  }
}
