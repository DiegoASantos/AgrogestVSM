{
  "expo": {
    "name": "AgroGest VSM",
    "slug": "agrogest-vsm-mobile-pilot",
    "scheme": "agrogest-vsm",
    "platforms": ["android"],
    "version": "0.1.6",
    "icon": "./assets/images/icon_vsm.png",
    "orientation": "portrait",
    "splash": {
      "image": "./assets/images/logo_vsm_transparente_4k.webp",
      "resizeMode": "contain",
      "backgroundColor": "#064b31"
    },
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "androidNavigationBar": {
      "backgroundColor": "#064b31",
      "barStyle": "light-content"
    },
    "android": {
      "package": "com.diegoasantos.agrogestvsm",
      "versionCode": 7,
      "icon": "./assets/images/icon_vsm.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive_icon_vsm.png",
        "backgroundColor": "#F7F3E8"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite usar la ubicacion del dispositivo para registrar la ubicacion de la visita de campo."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3451fa28-381f-46bc-8e91-2418748554a1"
      }
    },
    "owner": "diegosv",
    "updates": {
      "url": "https://u.expo.dev/3451fa28-381f-46bc-8e91-2418748554a1"
    },
    "ios": {}
  }
}
