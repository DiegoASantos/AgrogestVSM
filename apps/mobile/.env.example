# Production: used by EAS Build and EAS Update.
# EXPO_PUBLIC_API_URL=https://agrogest-vsm-api.onrender.com

# Development: use your computer LAN IP instead of 127.0.0.1 on physical devices.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001

# Native Android builds: create a restricted Maps SDK for Android key.
GOOGLE_MAPS_ANDROID_API_KEY=replace-with-restricted-android-key
