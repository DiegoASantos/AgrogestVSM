{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@agrogest/contracts": ["./packages/contracts/src/index.ts"],
      "@agrogest/contracts/*": ["./packages/contracts/src/*"],
      "@agrogest/validation": ["./packages/validation/src/index.ts"],
      "@agrogest/validation/*": ["./packages/validation/src/*"],
      "@agrogest/utils": ["./packages/utils/src/index.ts"],
      "@agrogest/utils/*": ["./packages/utils/src/*"]
    }
  }
}
